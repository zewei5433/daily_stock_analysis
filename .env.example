# ===================================
# A股自選股智能分析系統 - 環境變數配置模板（繁體版）
# ===================================

# 自選股列表（逗號分隔）
STOCK_LIST=600519,300750,002594

# ===================================
# STOCK 分組（你要求新增）
# ===================================
STOCK_GROUP_1=600519,300750
EMAIL_GROUP_1=user1@example.com

STOCK_GROUP_2=002594,AAPL
EMAIL_GROUP_2=user2@example.com

# ===================================
# Anspire Open API Keys
# ===================================
ANSPIRE_API_KEYS=你的_KEY_填這裡
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6

# ===================================
# 基礎資料源
# ===================================
TUSHARE_TOKEN=
TICKFLOW_API_KEY=

FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# ===================================
# AI 模型（至少填一個）
# ===================================
GEMINI_API_KEY=你的_KEY
DEEPSEEK_API_KEY=你的_KEY
AIHUBMIX_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===================================
# 搜尋引擎 API
# ===================================
TAVILY_API_KEYS=你的_KEY
SERPAPI_API_KEYS=
BRAVE_API_KEYS=

# ===================================
# 社群情緒分析（美股）
# ===================================
SOCIAL_SENTIMENT_API_KEY=你的_KEY
SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# 通知渠道（擇一或多）
# ===================================

# LINE / 微信 / 飛書 / Telegram
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email
EMAIL_SENDER=你的信箱
EMAIL_PASSWORD=你的SMTP密碼
EMAIL_RECEIVERS=user@example.com

# Webhook
CUSTOM_WEBHOOK_URLS=

# Discord
DISCORD_WEBHOOK_URL=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ===================================
# 通知群組路由（你新增需求）
# ===================================
NOTIFICATION_REPORT_CHANNELS=wechat,feishu,email
NOTIFICATION_ALERT_CHANNELS=wechat,telegram
NOTIFICATION_SYSTEM_ERROR_CHANNELS=email

# ===================================
# STOCK 群組通知映射（核心新增）
# ===================================
STOCK_GROUP_1=600519,300750
EMAIL_GROUP_1=user1@example.com

STOCK_GROUP_2=002594,AAPL
EMAIL_GROUP_2=user2@example.com

# ===================================
# AI 模型設定
# ===================================
LLM_TEMPERATURE=0.7
LLM_CHANNELS=deepseek,gemini
AGENT_MODE=true
AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout

# ===================================
# 搜尋設定
# ===================================
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=

# ===================================
# 分析策略
# ===================================
NEWS_STRATEGY_PROFILE=short
NEWS_MAX_AGE_DAYS=3
BIAS_THRESHOLD=5.0

# ===================================
# 回測
# ===================================
BACKTEST_ENABLED=true
BACKTEST_EVAL_WINDOW_DAYS=10

# ===================================
# 排程
# ===================================
SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00
RUN_IMMEDIATELY=true

# ===================================
# 系統
# ===================================
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false
