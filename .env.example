# ===================================
# 核心自選股智能分析系統 - 環境變數配置
# ===================================

# 預設核心監控列表（台股已自動補上 yfinance 專用後綴防止 404）
STOCK_LIST=VOO,QQQM,SMH,2330.TW

# ===================================
# STOCK 分組監控與 Email 路由設定
# ===================================
# 群組 1：大盤與科技主力 ETF
STOCK_GROUP_1=VOO,QQQM
EMAIL_GROUP_1=user1@example.com

# 群組 2：半導體核心與個股
STOCK_GROUP_2=SMH,2330.TW
EMAIL_GROUP_2=user2@example.com

# ===================================
# AI 大腦與核心模型設定
# ===================================
# 已自動填入歷史偵錯成功、調用 gemini-2.5-flash 的正式金鑰（前後無空格與中文）
GEMINI_API_KEY=AIzaSyD0Mr8U

# 備用 AI 渠道（若有需要，可在等號後方填入對應金鑰）
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AIHUBMIX_KEY=

# 系統當前啟動之 AI 渠道與核心模型參數
HERMES_PROVIDER=google
HERMES_MODEL=gemini-1.5-pro
LLM_TEMPERATURE=0.7
LLM_CHANNELS=gemini

# ===================================
# 代理人架構與技能擴充 (Agentic Skills)
# ===================================
AGENT_MODE=true
AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout

# ===================================
# 搜尋引擎 API（用於 AI 獲取即時財經新聞與情緒分析）
# ===================================
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=

# ===================================
# 基礎財經資料源設定
# ===================================
TUSHARE_TOKEN=
TICKFLOW_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# Longbridge 長橋證券 API 整合
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# 美股社群情緒分析
SOCIAL_SENTIMENT_API_KEY=
SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# 全自動通知渠道配置（已從歷史日誌提取成功憑證）
# ===================================
# 徹底移除舊日誌中夾帶的 Markdown 括號與帳號名稱，改用純數字與乾淨字串
TELEGRAM_BOT_TOKEN=8313684636:AAEbSGCMJts1nypCIsfWO3dzLatM6JDkbtA
TELEGRAM_CHAT_ID=11501189

# 其他通訊軟體 Webhook 備用
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
DISCORD_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# 電子郵件 SMTP 自動發信設定
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=user@example.com

# ===================================
# 報告與警報路由策略
# ===================================
NOTIFICATION_REPORT_CHANNELS=email
NOTIFICATION_ALERT_CHANNELS=telegram
NOTIFICATION_SYSTEM_ERROR_CHANNELS=email

# ===================================
# 量化分析與量價突破策略設定
# ===================================
NEWS_STRATEGY_PROFILE=short
NEWS_MAX_AGE_DAYS=3
# 價格跌破月線（20MA）或偏離度異常閾值
BIAS_THRESHOLD=5.0

# ===================================
# 雲端自動回測設定
# ===================================
BACKTEST_ENABLED=true
BACKTEST_EVAL_WINDOW_DAYS=10

# ===================================
# 排程與執行策略（配合 GitHub Actions 天天自動執行）
# ===================================
SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00
RUN_IMMEDIATELY=true

# ===================================
# 系統底層監控與線程設定
# ===================================
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false
